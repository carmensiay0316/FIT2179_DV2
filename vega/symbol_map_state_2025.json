{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 720,
  "height": 480,

  "projection": {
    "type": "mercator",
    "center": [134, -28],
    "scale": 650
  },

  "layer": [
    {
      "data": {
        "url": "https://raw.githubusercontent.com/rowanhogan/australian-states/master/states.geojson",
        "format": {
          "type": "json",
          "property": "features"
        }
      },
      "mark": {
        "type": "geoshape",
        "fill": "#eef2f5",
        "stroke": "white",
        "strokeWidth": 1
      }
    },
    {
      "data": {
        "url": "data/students_state_centroids_2025.csv"
      },
      "mark": {
        "type": "circle",
        "opacity": 0.75,
        "stroke": "white",
        "strokeWidth": 1.2
      },
      "encoding": {
        "longitude": {
          "field": "longitude",
          "type": "quantitative"
        },
        "latitude": {
          "field": "latitude",
          "type": "quantitative"
        },
        "size": {
          "field": "enrolments",
          "type": "quantitative",
          "title": "2025 enrolments",
          "scale": {
            "range": [120, 6000]
          },
          "legend": {
            "format": "~s",
            "tickCount": 6
          }
        },
        "color": {
          "field": "enrolments",
          "type": "quantitative",
          "title": "2025 enrolments",
          "scale": {
            "scheme": "blues"
          }
        },
        "tooltip": [
          {
            "field": "state_name",
            "type": "nominal",
            "title": "State"
          },
          {
            "field": "state",
            "type": "nominal",
            "title": "Abbreviation"
          },
          {
            "field": "enrolments",
            "type": "quantitative",
            "title": "2025 enrolments",
            "format": ","
          }
        ]
      }
    },
    {
      "data": {
        "url": "data/students_state_centroids_2025.csv"
      },
      "mark": {
        "type": "text",
        "fontSize": 12,
        "fontWeight": "bold",
        "dy": -10
      },
      "encoding": {
        "longitude": {
          "field": "longitude",
          "type": "quantitative"
        },
        "latitude": {
          "field": "latitude",
          "type": "quantitative"
        },
        "text": {
          "field": "state",
          "type": "nominal"
        }
      }
    }
  ]
}