{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 520,
  "height": 380,

  "data": {
    "url": "data/students_sector_year.csv"
  },

  "transform": [
    {
      "calculate": "datum.sector == 'VET' ? 1 : datum.sector == 'Higher Education' ? 2 : datum.sector == 'ELICOS' ? 3 : datum.sector == 'Non-award' ? 4 : datum.sector == 'Schools' ? 5 : 6",
      "as": "sector_order"
    },
    {
      "joinaggregate": [
        {
          "op": "sum",
          "field": "enrolments",
          "as": "year_total"
        }
      ],
      "groupby": ["year"]
    },
    {
      "calculate": "datum.enrolments / datum.year_total",
      "as": "share"
    }
  ],

  "mark": {
    "type": "area",
    "tooltip": true
  },

  "encoding": {
    "x": {
      "field": "year",
      "type": "ordinal",
      "title": "Year",
      "axis": {
        "labelAngle": 0
      }
    },

    "y": {
      "field": "enrolments",
      "type": "quantitative",
      "title": "International student enrolments",
      "stack": "zero",
      "axis": {
        "format": "~s",
        "tickCount": 6
      }
    },

    "color": {
      "field": "sector",
      "type": "nominal",
      "title": "Education sector",
      "scale": {
        "domain": [
          "VET",
          "Higher Education",
          "ELICOS",
          "Non-award",
          "Schools"
        ],
        "range": [
          "#CAD2C5",
          "#84A98C",
          "#52796F",
          "#354F52",
          "#2F3E46"
        ]
      },
      "legend": {
        "orient": "right",
        "titleFontSize": 12,
        "labelFontSize": 11
      }
    },

    "order": {
      "field": "sector_order",
      "type": "quantitative",
      "sort": "ascending"
    },

    "tooltip": [
      {
        "field": "sector",
        "type": "nominal",
        "title": "Sector"
      },
      {
        "field": "year",
        "type": "ordinal",
        "title": "Year"
      },
      {
        "field": "enrolments",
        "type": "quantitative",
        "title": "Sector enrolments",
        "format": ","
      },
      {
        "field": "share",
        "type": "quantitative",
        "title": "Share of year total",
        "format": ".1%"
      },
      {
        "field": "year_total",
        "type": "quantitative",
        "title": "Total enrolments in year",
        "format": ","
      }
    ]
  },

  "config": {
    "view": {
      "stroke": null
    },
    "font": "Arial"
  }
}