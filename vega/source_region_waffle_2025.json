{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": 650,
  "height": 420,

  "data": {
    "url": "data/source_region_waffle_2025.csv",
    "format": {
      "type": "csv",
      "parse": {
        "x": "number",
        "y": "number",
        "enrolments": "number",
        "share": "number",
        "tiles": "number",
        "tile_id": "number"
      }
    }
  },

  "mark": {
    "type": "rect",
    "stroke": "white",
    "strokeWidth": 1.2
  },

  "encoding": {
    "x": {
      "field": "x",
      "type": "ordinal",
      "axis": null,
      "sort": "ascending"
    },

    "y": {
      "field": "y",
      "type": "ordinal",
      "axis": null,
      "sort": "descending"
    },

    "color": {
      "field": "region",
      "type": "nominal",
      "title": "Source region",
      "scale": {
        "domain": [
          "North-East Asia",
          "Southern and Central Asia",
          "South-East Asia",
          "Americas",
          "Africa",
          "North-West Europe",
          "Oceania"
        ],
        "range": [
          "#EDE0D4",
          "#E6CCB2",
          "#DDB892",
          "#B08968",
          "#7F5539",
          "#9C6644",
          "#B08569"
        ]
      },
      "legend": {
        "orient": "bottom",
        "direction": "horizontal",
        "columns": 3,
        "titleFontSize": 12,
        "labelFontSize": 11,
        "symbolSize": 90
      }
    },

    "tooltip": [
      {
        "field": "region",
        "type": "nominal",
        "title": "Source region"
      },
      {
        "field": "enrolment_label",
        "type": "nominal",
        "title": "Top-country enrolments"
      },
      {
        "field": "share_label",
        "type": "nominal",
        "title": "Share"
      }
    ]
  },

  "config": {
    "view": {
      "stroke": null
    },
    "font": "Arial"
  }
}