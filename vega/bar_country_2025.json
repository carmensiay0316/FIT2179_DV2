{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 340,
  "height": 320,
  "data": {
    "url": "data/students_country_2025_top20.csv"
  },
  "encoding": {
    "y": {
      "field": "country",
      "type": "nominal",
      "sort": {
        "field": "enrolments",
        "op": "sum",
        "order": "descending"
      },
      "title": null,
      "axis": {
        "labelFontSize": 12,
        "labelLimit": 180
      }
    },
    "x": {
      "field": "enrolments",
      "type": "quantitative",
      "title": "International student enrolments in 2025",
      "scale": {
        "domain": [0, 250000]
      },
      "axis": {
        "values": [0, 50000, 100000, 150000, 200000, 250000],
        "labelExpr": "format(datum.value, ',')",
        "labelFontSize": 11,
        "titleFontSize": 12
      }
    },
    "tooltip": [
      {
        "field": "country",
        "type": "nominal",
        "title": "Source country"
      },
      {
        "field": "enrolments",
        "type": "quantitative",
        "title": "Enrolments",
        "format": ","
      }
    ]
  },
  "layer": [
    {
      "mark": {
        "type": "rule",
        "strokeWidth": 2
      },
      "encoding": {
        "x": {
          "datum": 0
        },
        "x2": {
          "field": "enrolments"
        }
      }
    },
    {
      "mark": {
        "type": "circle",
        "size": 160
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "dx": 8,
        "fontSize": 12
      },
      "encoding": {
        "text": {
          "field": "enrolments",
          "type": "quantitative",
          "format": ","
        }
      }
    }
  ]
}