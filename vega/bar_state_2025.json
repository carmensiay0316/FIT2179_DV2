{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 340,
  "height": 320,
  "data": {
    "url": "data/students_state_2025.csv"
  },
  "encoding": {
    "y": {
      "field": "state",
      "type": "nominal",
      "sort": {
        "field": "enrolments",
        "order": "descending"
      },
      "title": null,
      "axis": {
        "labelFontSize": 12
      }
    },
    "x": {
      "field": "enrolments",
      "type": "quantitative",
      "title": "International student enrolments in 2025",
      "scale": {
        "domain": [0, 450000]
      },
      "axis": {
        "values": [0, 100000, 200000, 300000, 400000],
        "labelExpr": "format(datum.value, ',')",
        "labelFontSize": 11,
        "titleFontSize": 12
      }
    },
    "tooltip": [
      {
        "field": "state",
        "type": "nominal",
        "title": "State"
      },
      {
        "field": "enrolments",
        "type": "quantitative",
        "title": "Enrolments",
        "format": ","
      }
    ]
  },
  "layer": [
    {
      "mark": {
        "type": "bar"
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "dx": 6,
        "fontSize": 12
      },
      "encoding": {
        "text": {
          "field": "enrolments",
          "type": "quantitative",
          "format": ","
        }
      }
    }
  ]
}