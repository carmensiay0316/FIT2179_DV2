    }
  ],

  "spacing": 14,

  "config": {
    "view": {
      "stroke": null
    },
    "font": "Arial",
    "axis": {
      "grid": true,
      "gridColor": "#e5e7eb",
      "labelFontSize": 11,
      "titleFontSize": 12
