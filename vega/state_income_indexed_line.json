              "as": "income_index"
            },
            {
              "calculate": "datum.income_million_num / 1000",
              "as": "income_billion"
            },
            {
              "calculate": "datum.State == 'NSW' ? 'New South Wales' : datum.State == 'VIC' ? 'Victoria' : datum.State == 'QLD' || datum.State == 'QL' ? 'Queensland' : datum.State == 'WA' ? 'Western Australia' : datum.State == 'SA' ? 'South Australia' : datum.State == 'TAS' ? 'Tasmania' : datum.State == 'ACT' ? 'Australian Capital Territory' : datum.State == 'NT' ? 'Northern Territory' : datum.State",
              "as": "state_name_full"
            },
            {
              "filter": "selected_income_state !== '' && datum.state_name_full === selected_income_state && datum.financial_year === selected_income_year"
            },
            {
              "calculate": "'Financial year: ' + datum.financial_year",
              "as": "year_line"
            },
            {
              "calculate": "'Index: ' + format(datum.income_index, '.1f')",
              "as": "index_line"
            },
            {
              "calculate": "'Export income: A$' + format(datum.income_billion, ',.1f') + ' billion'",
              "as": "income_billion_line"
            },
            {
              "calculate": "'Export income: A$' + format(datum.income_million_num, ',.0f') + ' million'",
              "as": "income_million_line"
            }
          ],

          "layer": [
