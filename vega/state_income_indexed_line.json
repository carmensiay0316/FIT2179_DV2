{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": 750,
  "height": 430,

  "title": {
    "text": "How strongly did education export income recover by state?",
    "subtitle": "Index, where each state’s 2019–20 income equals 100.",
    "anchor": "start",
    "fontSize": 18,
    "subtitleFontSize": 12,
    "subtitleColor": "#555"
  },

  "data": {
    "url": "data/education_export_income.csv"
  },

  "transform": [
    {
      "fold": [
        "2019-20",
        "2020-21",
        "2021-22",
        "2022-23",
        "2023-24",
        "2024-25"
      ],
      "as": ["financial_year", "income_million"]
    },
    {
      "calculate": "datum.income_million / datum['2019-20'] * 100",
      "as": "income_index"
    },
    {
      "calculate": "datum.income_million / 1000",
      "as": "income_billion"
    },
    {
      "calculate": "datum.State == 'NSW' ? 'New South Wales' : datum.State == 'VIC' ? 'Victoria' : datum.State == 'QLD' || datum.State == 'QL' ? 'Queensland' : datum.State == 'WA' ? 'Western Australia' : datum.State == 'SA' ? 'South Australia' : datum.State == 'TAS' ? 'Tasmania' : datum.State == 'ACT' ? 'Australian Capital Territory' : datum.State == 'NT' ? 'Northern Territory' : datum.State",
      "as": "state_name_full"
    }
  ],

  "layer": [
    {
      "mark": {
        "type": "rule",
        "strokeDash": [4, 4],
        "color": "#777"
      },
      "encoding": {
        "y": {
          "datum": 100
        }
      }
    },

    {
      "mark": {
        "type": "line",
        "point": true,
        "strokeWidth": 2.5
      },

      "encoding": {
        "x": {
          "field": "financial_year",
          "type": "ordinal",
          "title": "Financial year",
          "sort": [
            "2019-20",
            "2020-21",
            "2021-22",
            "2022-23",
            "2023-24",
            "2024-25"
          ],
          "axis": {
            "labelAngle": 0
          }
        },

        "y": {
          "field": "income_index",
          "type": "quantitative",
          "title": "Index, 2019–20 = 100",
          "scale": {
            "domain": [0, 220]
          }
        },

        "color": {
          "field": "state_name_full",
          "type": "nominal",
          "title": "State",
          "scale": {
            "domain": [
              "New South Wales",
              "Victoria",
              "Queensland",
              "Western Australia",
              "South Australia",
              "Tasmania",
              "Australian Capital Territory",
              "Northern Territory"
            ],
            "range": [
              "#797D62",
              "#9B9B7A",
              "#D9AE94",
              "#F1DCA7",
              "#FFCB69",
              "#D08C60",
              "#997B66",
              "#AD9585"
            ]
          },
          "legend": {
            "orient": "right",
            "titleFontSize": 12,
            "labelFontSize": 11,
            "labelLimit": 170
          }
        },

        "detail": {
          "field": "state_name_full",
          "type": "nominal"
        },

        "tooltip": [
          {
            "field": "state_name_full",
            "type": "nominal",
            "title": "State"
          },
          {
            "field": "financial_year",
            "type": "ordinal",
            "title": "Financial year"
          },
          {
            "field": "income_million",
            "type": "quantitative",
            "title": "Export income, A$ million",
            "format": ","
          },
          {
            "field": "income_billion",
            "type": "quantitative",
            "title": "Export income, A$ billion",
            "format": ".1f"
          },
          {
            "field": "income_index",
            "type": "quantitative",
            "title": "Index, 2019–20 = 100",
            "format": ".1f"
          }
        ]
      }
    }
  ],

  "config": {
    "view": {
      "stroke": null
    },
    "font": "Arial",
    "axis": {
      "grid": true,
      "labelFontSize": 11,
      "titleFontSize": 12
    },
    "legend": {
      "labelFontSize": 11,
      "titleFontSize": 12
    }
  }
}