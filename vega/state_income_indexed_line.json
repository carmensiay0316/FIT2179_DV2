{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "params": [
    {
      "name": "selected_income_state",
      "value": ""
    },
    {
      "name": "selected_income_year",
      "value": ""
    }
  ],

  "hconcat": [
    {
      "width": 585,
      "height": 380,

      "data": {
        "url": "data/education_export_income.csv"
      },

      "transform": [
        {
          "fold": [
            "2019-20",
            "2020-21",
            "2021-22",
            "2022-23",
            "2023-24",
            "2024-25"
          ],
          "as": ["financial_year", "income_million"]
        },
        {
          "calculate": "toNumber(replace(datum.income_million + '', /,/g, ''))",
          "as": "income_million_num"
        },
        {
          "calculate": "toNumber(replace(datum['2019-20'] + '', /,/g, ''))",
          "as": "base_income"
        },
        {
          "calculate": "datum.income_million_num / datum.base_income * 100",
          "as": "income_index"
        },
        {
          "calculate": "datum.income_million_num / 1000",
          "as": "income_billion"
        },
        {
          "calculate": "datum.State == 'NSW' ? 'New South Wales' : datum.State == 'VIC' ? 'Victoria' : datum.State == 'QLD' || datum.State == 'QL' ? 'Queensland' : datum.State == 'WA' ? 'Western Australia' : datum.State == 'SA' ? 'South Australia' : datum.State == 'TAS' ? 'Tasmania' : datum.State == 'ACT' ? 'Australian Capital Territory' : datum.State == 'NT' ? 'Northern Territory' : datum.State",
          "as": "state_name_full"
        }
      ],

      "layer": [
        {
          "mark": {
            "type": "rule",
            "strokeDash": [4, 4],
            "color": "#777"
          },
          "encoding": {
            "y": {
              "datum": 100
            }
          }
        },

        {
          "mark": {
            "type": "line",
            "point": {
              "filled": true,
              "size": 70
            },
            "strokeWidth": 2.5,
            "tooltip": true,
            "cursor": "pointer"
          },
          "encoding": {
            "x": {
              "field": "financial_year",
              "type": "ordinal",
              "title": "Financial year",
              "sort": [
                "2019-20",
                "2020-21",
                "2021-22",
                "2022-23",
                "2023-24",
                "2024-25"
              ],
              "axis": {
                "labelAngle": 0
              }
            },

            "y": {
              "field": "income_index",
              "type": "quantitative",
              "title": "Index, 2019–20 = 100",
              "scale": {
                "domain": [0, 220]
              }
            },

            "color": {
              "field": "state_name_full",
              "type": "nominal",
              "title": "State",
              "scale": {
                "domain": [
                  "New South Wales",
                  "Victoria",
                  "Queensland",
                  "Western Australia",
                  "South Australia",
                  "Tasmania",
                  "Australian Capital Territory",
                  "Northern Territory"
                ],
                "range": [
                  "#797D62",
                  "#9B9B7A",
                  "#D9AE94",
                  "#F1DCA7",
                  "#FFCB69",
                  "#D08C60",
                  "#997B66",
                  "#AD9585"
                ]
              },
              "legend": {
                "orient": "bottom",
                "direction": "horizontal",
                "columns": 2,
                "titleFontSize": 12,
                "labelFontSize": 11,
                "labelLimit": 210,
                "symbolSize": 90
              }
            },

            "opacity": {
              "condition": {
                "test": "selected_income_state === '' || datum.state_name_full === selected_income_state",
                "value": 1
              },
              "value": 0.25
            },

            "strokeWidth": {
              "condition": {
                "test": "selected_income_state !== '' && datum.state_name_full === selected_income_state",
                "value": 4
              },
              "value": 2.4
            },

            "detail": {
              "field": "state_name_full",
              "type": "nominal"
            },

            "tooltip": [
              {
                "field": "state_name_full",
                "type": "nominal",
                "title": "State"
              },
              {
                "field": "financial_year",
                "type": "ordinal",
                "title": "Financial year"
              },
              {
                "field": "income_million_num",
                "type": "quantitative",
                "title": "Export income, A$ million",
                "format": ","
              },
              {
                "field": "income_billion",
                "type": "quantitative",
                "title": "Export income, A$ billion",
                "format": ".1f"
              },
              {
                "field": "income_index",
                "type": "quantitative",
                "title": "Index, 2019–20 = 100",
                "format": ".1f"
              }
            ]
          }
        }
      ]
    },

