{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 520,
  "height": 420,

  "data": {
    "url": "data/students_sector_2025.csv"
  },

  "transform": [
    {
      "joinaggregate": [
        {
          "op": "sum",
          "field": "enrolments",
          "as": "total_enrolments"
        }
      ]
    },
    {
      "calculate": "datum.enrolments / datum.total_enrolments * 100",
      "as": "share"
    },
    {
      "calculate": "format(datum.share, '.1f') + '%'",
      "as": "share_label"
    }
  ],

  "mark": {
    "type": "arc",
    "innerRadius": 85,
    "outerRadius": 160,
    "stroke": "white",
    "strokeWidth": 2
  },

  "encoding": {
    "theta": {
      "field": "enrolments",
      "type": "quantitative"
    },
    "color": {
      "field": "sector",
      "type": "nominal",
      "title": "Education sector",
      "scale": {
        "domain": [
          "Higher Education",
          "VET",
          "ELICOS",
          "Non-award",
          "Schools"
        ],
        "range": [
          "#2F6DA3",
          "#6FAF8F",
          "#E3C66B",
          "#C97C7C",
          "#B7D4E8"
        ]
      },
      "legend": {
        "orient": "bottom",
        "direction": "horizontal",
        "columns": 3
      }
    },
    "tooltip": [
      {
        "field": "sector",
        "type": "nominal",
        "title": "Sector"
      },
      {
        "field": "enrolments",
        "type": "quantitative",
        "title": "2025 enrolments",
        "format": ","
      },
      {
        "field": "share",
        "type": "quantitative",
        "title": "Share of sector total",
        "format": ".1f"
      }
    ]
  },

  "config": {
    "view": {
      "stroke": null
    }
  }
}