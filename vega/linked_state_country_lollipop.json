{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": 780,
  "height": 390,

  "params": [
    {
      "name": "selected_state_name",
      "value": "New South Wales",
      "bind": {
        "input": "select",
        "name": "Selected state: ",
        "options": [
          "New South Wales",
          "Victoria",
          "Queensland",
          "Western Australia",
          "South Australia",
          "Australian Capital Territory",
          "Tasmania",
          "Northern Territory"
        ]
      }
    },
    {
      "name": "selected_lollipop_country",
      "value": ""
    }
  ],

  "data": {
    "url": "data/state_country_2025_top20.csv",
    "format": {
      "type": "csv",
      "parse": {
        "enrolments": "number",
        "share_of_state": "number",
        "state_total": "number"
      }
    }
  },

  "transform": [
    {
      "filter": "datum.state_name == selected_state_name"
    },
    {
      "calculate": "datum.region == 'East Asia' ? 'North-East Asia' : datum.region == 'South Asia' ? 'Southern and Central Asia' : datum.region == 'Southeast Asia' ? 'South-East Asia' : datum.region == 'South America' ? 'Americas' : datum.region",
      "as": "source_region"
    },
    {
      "calculate": "format(datum.enrolments, ',.0f')",
      "as": "enrolment_label"
    },
    {
      "calculate": "format(datum.share_of_state, '.1%')",
      "as": "share_label"
    }
  ],

  "encoding": {
    "y": {
      "field": "nationality",
      "type": "nominal",
      "sort": {
        "field": "enrolments",
        "op": "max",
        "order": "descending"
      },
      "title": null,
      "axis": {
        "labelLimit": 230,
        "labelFontSize": 11
      }
    }
  },

  "layer": [
    {
      "mark": {
        "type": "bar",
        "size": 2,
        "cursor": "pointer"
      },
      "encoding": {
        "x": {
          "field": "enrolments",
          "type": "quantitative",
          "title": "YTD enrolments in 2025",
          "scale": {
            "zero": true,
            "nice": true
          },
          "axis": {
            "format": ",",
            "tickCount": 6,
            "labelExpr": "format(datum.value, ',')",
            "labelFontSize": 11,
            "titleFontSize": 12
          }
        },
        "color": {
          "condition": {
            "test": "selected_lollipop_country !== '' && datum.nationality === selected_lollipop_country",
            "value": "#7F5539"
          },
          "value": "#D8D3CF"
        },
        "opacity": {
          "condition": {
            "test": "selected_lollipop_country === '' || datum.nationality === selected_lollipop_country",
            "value": 1
          },
          "value": 0.3
        }
      }
    },

    {
      "mark": {
        "type": "circle",
        "size": 95,
        "tooltip": true,
        "stroke": "#6D6875",
        "strokeWidth": 0.7,
        "cursor": "pointer"
      },
      "encoding": {
        "x": {
          "field": "enrolments",
          "type": "quantitative",
          "title": "YTD enrolments in 2025",
          "scale": {
            "zero": true,
            "nice": true
          },
          "axis": {
            "format": ",",
            "tickCount": 6,
            "labelExpr": "format(datum.value, ',')"
          }
        },
        "color": {
          "field": "source_region",
          "type": "nominal",
          "title": "Source region",
          "scale": {
            "domain": [
              "North-East Asia",
              "Southern and Central Asia",
              "South-East Asia",
              "Americas",
              "Africa",
              "North-West Europe",
              "Oceania"
            ],
            "range": [
              "#EDE0D4",
              "#E6CCB2",
              "#DDB892",
              "#B08968",
              "#7F5539",
              "#9C6644",
              "#B08569"
            ]
          },
          "legend": {
            "orient": "top",
            "direction": "horizontal",
            "columns": 4,
            "titleFontSize": 12,
            "labelFontSize": 11,
            "labelLimit": 170,
            "symbolSize": 90
          }
        },
        "size": {
          "condition": {
            "test": "selected_lollipop_country !== '' && datum.nationality === selected_lollipop_country",
            "value": 150
          },
          "value": 95
        },
        "strokeWidth": {
          "condition": {
            "test": "selected_lollipop_country !== '' && datum.nationality === selected_lollipop_country",
            "value": 2.5
          },
          "value": 0.7
        },
        "opacity": {
          "condition": {
            "test": "selected_lollipop_country === '' || datum.nationality === selected_lollipop_country",
            "value": 1
          },
          "value": 0.3
        },
        "tooltip": [
          {
            "field": "state_name",
            "type": "nominal",
            "title": "Selected state"
          },
          {
            "field": "nationality",
            "type": "nominal",
            "title": "Source country"
          },
          {
            "field": "source_region",
            "type": "nominal",
            "title": "Source region"
          },
          {
            "field": "enrolments",
            "type": "quantitative",
            "title": "2025 enrolments",
            "format": ","
          },
          {
            "field": "share_of_state",
            "type": "quantitative",
            "title": "Share of selected state",
            "format": ".1%"
          }
        ]
      }
    },

    {
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "dx": 8,
        "fontSize": 11,
        "color": "#333",
        "cursor": "pointer"
      },
      "encoding": {
        "x": {
          "field": "enrolments",
          "type": "quantitative",
          "scale": {
            "zero": true,
            "nice": true
          }
        },
        "text": {
          "field": "enrolment_label",
          "type": "nominal"
        },
        "opacity": {
          "condition": {
            "test": "selected_lollipop_country === '' || datum.nationality === selected_lollipop_country",
            "value": 1
          },
          "value": 0.3
        }
      }
    },

    {
      "transform": [
        {
          "filter": "selected_lollipop_country !== '' && datum.nationality === selected_lollipop_country"
        }
      ],
      "mark": {
        "type": "rect",
        "fill": "#FFF7ED",
        "stroke": "#B08968",
        "strokeWidth": 1,
        "cornerRadius": 6,
        "opacity": 0.96
      },
      "encoding": {
        "x": {
          "value": 545
        },
        "x2": {
          "value": 775
        },
        "y": {
          "value": 195
        },
        "y2": {
          "value": 320
        }
      }
    },

    {
      "transform": [
        {
          "filter": "selected_lollipop_country !== '' && datum.nationality === selected_lollipop_country"
        },
        {
          "calculate": "'Source country: ' + datum.nationality",
          "as": "country_annotation"
        }
      ],
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "top",
        "fontSize": 11,
        "fontWeight": "bold",
        "color": "#7F5539",
        "limit": 215
      },
      "encoding": {
        "x": {
          "value": 560
        },
        "y": {
          "value": 212
        },
        "text": {
          "field": "country_annotation",
          "type": "nominal"
        }
      }
    },

    {
      "transform": [
        {
          "filter": "selected_lollipop_country !== '' && datum.nationality === selected_lollipop_country"
        },
        {
          "calculate": "'Source region: ' + datum.source_region",
          "as": "region_annotation"
        }
      ],
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "top",
        "fontSize": 11,
        "color": "#333",
        "limit": 215
      },
      "encoding": {
        "x": {
          "value": 560
        },
        "y": {
          "value": 238
        },
        "text": {
          "field": "region_annotation",
          "type": "nominal"
        }
      }
    },

    {
      "transform": [
        {
          "filter": "selected_lollipop_country !== '' && datum.nationality === selected_lollipop_country"
        },
        {
          "calculate": "'2025 enrolments: ' + datum.enrolment_label",
          "as": "enrolment_annotation"
        }
      ],
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "top",
        "fontSize": 11,
        "color": "#333",
        "limit": 215
      },
      "encoding": {
        "x": {
          "value": 560
        },
        "y": {
          "value": 264
        },
        "text": {
          "field": "enrolment_annotation",
          "type": "nominal"
        }
      }
    },

    {
      "transform": [
        {
          "filter": "selected_lollipop_country !== '' && datum.nationality === selected_lollipop_country"
        },
        {
          "calculate": "'Share of state: ' + datum.share_label",
          "as": "share_annotation"
        }
      ],
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "top",
        "fontSize": 11,
        "color": "#333",
        "limit": 215
      },
      "encoding": {
        "x": {
          "value": 560
        },
        "y": {
          "value": 290
        },
        "text": {
          "field": "share_annotation",
          "type": "nominal"
        }
      }
    }
  ],

  "config": {
    "view": {
      "stroke": null
    },
    "font": "Arial",
    "axis": {
      "labelFontSize": 11,
      "titleFontSize": 12,
      "gridColor": "#e5e7eb"
    },
    "legend": {
      "labelFontSize": 11,
      "titleFontSize": 12
    }
  }
}