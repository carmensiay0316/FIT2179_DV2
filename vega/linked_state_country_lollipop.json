{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 680,
  "height": 430,
  "title": {
    "text": "Top source countries for the selected state",
    "subtitle": "Select a state or click a state on the choropleth map",
    "anchor": "start",
    "fontSize": 18,
    "subtitleFontSize": 13
  },
  "params": [
    {
      "name": "selected_state_name",
      "value": "Australian Capital Territory",
      "bind": {
        "input": "select",
        "name": "Selected state: ",
        "options": [
          "Australian Capital Territory",
          "New South Wales",
          "Northern Territory",
          "Queensland",
          "South Australia",
          "Tasmania",
          "Victoria",
          "Western Australia"
        ]
      }
    }
  ],
  "data": {
    "url": "data/state_country_2025_top20.csv",
    "format": {
        "type": "csv",
        "parse": {
        "enrolments": "number",
        "share_of_state": "number"
        }
    }
    },
  "transform": [
    {
      "filter": "datum.state_name == selected_state_name"
    }
  ],
  "encoding": {
    "y": {
      "field": "nationality",
      "type": "nominal",
      "sort": {
        "field": "enrolments",
        "op": "max",
        "order": "descending"
      },
      "title": null,
      "axis": {
        "labelLimit": 220
      }
    }
  },
  "layer": [
    {
      "mark": {
        "type": "bar",
        "height": 2,
        "color": "#9aa7b1"
      },
      "encoding": {
        "x": {
          "field": "enrolments",
          "type": "quantitative",
          "title": "YTD enrolments in 2025",
          "axis": {
            "format": ",",
            "labelExpr": "format(datum.value, ',')"
          }
        }
      }
    },
    {
      "mark": {
        "type": "circle",
        "size": 95,
        "tooltip": true
      },
      "encoding": {
        "x": {
          "field": "enrolments",
          "type": "quantitative",
          "title": "YTD enrolments in 2025",
          "axis": {
            "format": ","
          }
        },
        "color": {
          "field": "region",
          "type": "nominal",
          "title": "Region"
        },
        "tooltip": [
          {
            "field": "state_name",
            "type": "nominal",
            "title": "State"
          },
          {
            "field": "nationality",
            "type": "nominal",
            "title": "Nationality"
          },
          {
            "field": "region",
            "type": "nominal",
            "title": "Region"
          },
          {
            "field": "enrolments",
            "type": "quantitative",
            "title": "2025 enrolments",
            "format": ","
          },
          {
            "field": "share_of_state",
            "type": "quantitative",
            "title": "Share of selected state",
            "format": ".1%"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "dx": 8,
        "fontSize": 11,
        "color": "#333"
      },
      "encoding": {
        "x": {
          "field": "enrolments",
          "type": "quantitative"
        },
        "text": {
          "field": "enrolments",
          "type": "quantitative",
          "format": ","
        }
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "labelFontSize": 11,
      "titleFontSize": 12
    },
    "legend": {
      "labelFontSize": 11,
      "titleFontSize": 12
    }
  }
}